# Plately — environment variables
# Copy this file to .env and fill in your keys

# Optional but recommended in production
NODE_ENV=development
DATA_DIR=./data

# Anthropic API key — enables Claude-powered recipe extraction (much better titles + steps)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Meta credentials — only needed for Instagram import
META_APP_ID=
META_APP_SECRET=
